{
  "manifest_version": 3,
  "name": "finite feed",
  "version": "1.0.0",
  "description": "removes algorithmic recommendations from youtube. search only.",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
